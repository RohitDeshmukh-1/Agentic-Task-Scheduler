# ═══════════════════════════════════════════════════════════════
#  TaskPilot — Railway Environment Variables
#  Copy these into Railway → Project → Variables tab
# ═══════════════════════════════════════════════════════════════

# ── LLM (Groq — free tier works fine) ──────────────────────────
# Get key from: https://console.groq.com
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# ── Database ────────────────────────────────────────────────────
# Railway PostgreSQL: add the Postgres plugin in your Railway project.
# Then copy the DATABASE_URL from the Postgres plugin's "Connect" tab.
# It will look like: postgresql://postgres:xxxx@monorail.proxy.rlwy.net:PORT/railway
# IMPORTANT: Replace "postgresql://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@monorail.proxy.rlwy.net:PORT/railway

# ── Telegram ────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Use polling on Railway (simpler, no webhook setup needed)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_SECRET=taskpilot_telegram_2026

# ── Application ─────────────────────────────────────────────────
APP_NAME=TaskPilot
APP_ENV=production
APP_SECRET_KEY=generate-a-random-64-char-string-here
APP_HOST=0.0.0.0
# PORT is auto-injected by Railway — do NOT set this manually
LOG_LEVEL=INFO

# ── Scheduler ───────────────────────────────────────────────────
MORNING_REMINDER_HOUR=8
MORNING_REMINDER_MINUTE=0
NIGHT_CHECK_HOUR=21
NIGHT_CHECK_MINUTE=0
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_HOUR=10

# ── Dashboard ───────────────────────────────────────────────────
DASHBOARD_ENABLED=true
# Add your Railway public domain here once deployed
CORS_ORIGINS=["https://your-app.up.railway.app","http://localhost:8000"]
