# ─── LLM Configuration ───────────────────────────────────────
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# ─── Database Configuration ──────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./taskbot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/taskbot

# ─── WhatsApp Configuration ──────────────────────────────────
WHATSAPP_MODE=console
# Options: console | meta_cloud
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# ─── Application Configuration ───────────────────────────────
APP_NAME=TaskPilot
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Scheduler Configuration ─────────────────────────────────
MORNING_REMINDER_HOUR=8
MORNING_REMINDER_MINUTE=0
NIGHT_CHECK_HOUR=21
NIGHT_CHECK_MINUTE=0
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_HOUR=10

# ─── Dashboard Configuration ─────────────────────────────────
DASHBOARD_ENABLED=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
