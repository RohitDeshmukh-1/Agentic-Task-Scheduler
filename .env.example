# ─── LLM Configuration ───────────────────────────────────────
# Get your free API key from: https://console.groq.com
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# ─── Database Configuration ──────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./taskbot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/taskbot

# ─── Telegram Configuration ──────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_MODE=webhook
# Options: webhook | polling
TELEGRAM_WEBHOOK_SECRET=taskpilot_telegram_2026

# ─── Application Configuration ───────────────────────────────
APP_NAME=TaskPilot
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Scheduler Configuration ─────────────────────────────────
MORNING_REMINDER_HOUR=8
MORNING_REMINDER_MINUTE=0
NIGHT_CHECK_HOUR=21
NIGHT_CHECK_MINUTE=0
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_HOUR=10

# ─── Dashboard Configuration ─────────────────────────────────
DASHBOARD_ENABLED=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
